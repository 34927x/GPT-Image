{
  "manifest_version": 3,
  "name": "GPT Multi-Account Rotator",
  "version": "3.0.0",
  "description": "Rotate ChatGPT accounts, bulk image gen, auto zip download.",
  "permissions": [
    "cookies", "storage", "webRequest", "alarms", "tabs", "downloads", "sidePanel"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://*.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "GPT Rotator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
