{
  "name": "bulk-gpt-extension",
  "version": "4.0.0",
  "private": true,
  "description": "Bulk-GPT worker extension — generates images via ChatGPT with rotating accounts",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build && node scripts/copy-manifest.mjs chrome",
    "build:firefox": "vite build && node scripts/copy-manifest.mjs firefox",
    "package": "npm run build && node scripts/zip.mjs"
  },
  "dependencies": {
    "lucide-preact": "^0.460.0",
    "preact": "^10.24.3"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.1",
    "@types/chrome": "^0.0.279",
    "@types/firefox-webext-browser": "^120.0.4",
    "@types/node": "^25.9.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.0.1"
  }
}
