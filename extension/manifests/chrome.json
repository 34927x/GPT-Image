{
  "manifest_version": 3,
  "name": "Bulk-GPT Worker",
  "version": "4.0.0",
  "description": "Worker extension for Bulk-GPT — generates images on chatgpt.com with rotating accounts in incognito tabs.",
  "permissions": [
    "cookies",
    "storage",
    "alarms",
    "tabs",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://*.openai.com/*",
    "https://*.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "incognito": "split",
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["assets/content-chatgpt.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "Bulk-GPT Worker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
