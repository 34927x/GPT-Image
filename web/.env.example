# MongoDB Atlas connection
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_DB=bulk_gpt

# Random 32+ char string used to sign session cookies
SESSION_SECRET=replace_me_with_a_long_random_string_min_32_chars

# Random token shared with the extension's Worker Mode
WORKER_TOKEN=replace_me_with_another_long_random_string

# Master admin key — paste this on /login to access /admin (no need to be in DB)
ADMIN_MASTER_KEY=BGT-ADMIN-CHANGE-ME

# Public site URL (used for CORS + extension allowlist)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Cloudinary for image hosting (falls back to MongoDB base64 if unset)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
